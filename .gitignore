```gitignore
# Service worker cache
.sw/

# Temporary files
*.tmp
*.temp

# Logs
*.log

# Environment files
.env
.env.local
.env.*

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Build artifacts
dist/
build/
*.min.js
*.min.css
*.bundle.js

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS generated files
.DS_Store
Thumbs.db
```